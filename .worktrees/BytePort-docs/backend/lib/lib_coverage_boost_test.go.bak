// Additional tests to boost coverage for crypto functions
func TestEncryptPassEdgeCases(t *testing.T) {
	tests := []string{
		"",                    // empty password
		" ",                   // single space
		"\t\n\r",              // whitespace chars
		"a",                   // single char
		"🔐🗝️",                // unicode
		strings.Repeat("x", 1000), // very long password
	}

	for _, password := range tests {
		t.Run(fmt.Sprintf("password-len-%d", len(password)), func(t *testing.T) {
			hash := EncryptPass(password)
			assert.NotEmpty(t, hash)
			assert.True(t, strings.HasPrefix(hash, "$argon2id$"))

			// Verify the hash validates correctly
			isValid := ValidatePass(password, hash)
			assert.True(t, isValid)
		})
	}
}

func TestValidatePassValidCases(t *testing.T) {
	// Test successful validation cases only
	validHash := EncryptPass("test123")
	assert.True(t, ValidatePass("test123", validHash))
	assert.False(t, ValidatePass("Test123", validHash)) // case sensitive
	assert.False(t, ValidatePass("wrong", validHash))
	assert.False(t, ValidatePass("", validHash)) // empty password

	// Test edge cases with valid hashes
	emptyPassHash := EncryptPass("")
	assert.True(t, ValidatePass("", emptyPassHash))
	assert.False(t, ValidatePass("not-empty", emptyPassHash))

	// Test unicode passwords
	unicodeHash := EncryptPass("🔐🗝️")
	assert.True(t, ValidatePass("🔐🗝️", unicodeHash))
	assert.False(t, ValidatePass("wrong", unicodeHash))
}

// Test the underlying comparePasswordAndHash function directly to test error paths
func TestComparePasswordAndHashErrorPaths(t *testing.T) {
	// Test with empty hash - this will return error instead of fatal
	match, err := comparePasswordAndHash("password", "")
	assert.Error(t, err)
	assert.False(t, match)
	assert.Equal(t, ErrInvalidHash, err)

	// Test with invalid hash format
	match, err = comparePasswordAndHash("password", "invalid-hash")
	assert.Error(t, err)
	assert.False(t, match)
	assert.Equal(t, ErrInvalidHash, err)

	// Test with malformed argon2 hash
	match, err = comparePasswordAndHash("password", "$argon2id$invalid")
	assert.Error(t, err)
	assert.False(t, match)
}

// Additional tests for auth functions to boost coverage
func TestInitAuthSystemSuccessPath(t *testing.T) {
	// Test that InitAuthSystem works correctly multiple times
	err := InitAuthSystem()
	assert.NoError(t, err)

	// Should be idempotent - calling again should not fail
	err = InitAuthSystem()
	assert.NoError(t, err)

	// Verify all keys exist
	_, err = keyring.Get(tokenKeyService, keyringUser)
	assert.NoError(t, err)
	
	_, err = keyring.Get(secretsKeyService, keyringUser)
	assert.NoError(t, err)
	
	_, err = keyring.Get(serviceKeyService, keyringUser)
	assert.NoError(t, err)
}

func TestGenerateTokenErrorPaths(t *testing.T) {
	// Clean up keyring first
	keyring.Delete(tokenKeyService, keyringUser)
	
	// Test without initialized auth system
	user := models.User{
		UUID:  "test-user",
		Email: "test@example.com",
	}

	// This should work because GenerateToken calls getSymmetricKey which creates key if needed
	token, err := GenerateToken(user)
	assert.NoError(t, err)
	assert.NotEmpty(t, token)

	// Test with user having empty UUID
	emptyUUIDUser := models.User{
		UUID:  "",
		Email: "test@example.com",
	}

	token, err = GenerateToken(emptyUUIDUser)
	assert.NoError(t, err) // Should still work
	assert.NotEmpty(t, token)

	// Test with user having empty email
	emptyEmailUser := models.User{
		UUID:  "test-user",
		Email: "",
	}

	token, err = GenerateToken(emptyEmailUser)
	assert.NoError(t, err) // Should still work
	assert.NotEmpty(t, token)
}

func TestGenerateNVMSTokenErrorPaths(t *testing.T) {
