func TestAuthenticateRequestDatabaseErrors(t *testing.T) {
	// Setup test database
	db, err := gorm.Open(sqlite.Open(":memory:"), &gorm.Config{})
	require.NoError(t, err)
	models.DB = db

	// Create table but don't insert any users
	err = db.Exec(`CREATE TABLE IF NOT EXISTS users (
		uuid TEXT PRIMARY KEY,
		name TEXT,
		email TEXT UNIQUE,
		password TEXT,
		aws_access_key_id TEXT DEFAULT '',
		aws_secret_access_key TEXT DEFAULT '',
		llm_provider TEXT DEFAULT '',
		llm_providers TEXT DEFAULT '{}',
		portfolio_root_endpoint TEXT DEFAULT '',
		portfolio_api_key TEXT DEFAULT '',
		created_at DATETIME,
		updated_at DATETIME
	)`).Error
	require.NoError(t, err)

	// Initialize auth system
	err = InitAuthSystem()
	require.NoError(t, err)

	// Generate token for non-existent user
	user := models.User{
		UUID:  "non-existent-user",
		Email: "nonexistent@example.com",
	}

	token, err := GenerateToken(user)
	require.NoError(t, err)

	// Try to authenticate - should fail because user doesn't exist in database
	authenticatedUser, err := AuthenticateRequest(token)
	assert.Error(t, err)
	assert.Nil(t, authenticatedUser)
	assert.Contains(t, err.Error(), "record not found")

	// Test with malformed token that causes parsing errors
	authenticatedUser, err = AuthenticateRequest("malformed.token.here")
	assert.Error(t, err)
	assert.Nil(t, authenticatedUser)

	// Test with empty token
	authenticatedUser, err = AuthenticateRequest("")
	assert.Error(t, err)
	assert.Nil(t, authenticatedUser)
}

func TestValidateTokenKeyringFailures(t *testing.T) {
	// Clean up keyring
	keyring.Delete(tokenKeyService, keyringUser)

	// Test validation without keyring setup (should fail)
	valid, token, err := ValidateToken("any-token")
	assert.Error(t, err)
	assert.False(t, valid)
	assert.Nil(t, token)

	// Setup minimal key
	err = ensureKeyExists(tokenKeyService, keyringUser)
	require.NoError(t, err)

	// Test with various invalid token formats
	invalidTokens := []string{
		"not.a.token",
		"v4.local.invalid",
		"",
		" ",
		"Bearer token",
		"random-string-123",
	}

	for _, invalidToken := range invalidTokens {
		t.Run(fmt.Sprintf("invalid-token-%s", invalidToken), func(t *testing.T) {
			valid, token, err := ValidateToken(invalidToken)
			assert.Error(t, err)
			assert.False(t, valid)
			assert.Nil(t, token)
		})
	}
}

