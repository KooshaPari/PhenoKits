# Primary BytePort API base (includes /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Optional: force local URLs regardless of window origin
# NEXT_PUBLIC_USE_LOCAL=true
# NEXT_PUBLIC_LOCAL_API_PORT=8080
# NEXT_PUBLIC_LOCAL_FRONTEND_PORT=3000

# Shared WorkOS / AuthKit configuration (re-use values from Zen)
NEXT_PUBLIC_AUTHKIT_DOMAIN=https://your-app.authkit.app
NEXT_PUBLIC_AUTHKIT_CLIENT_ID=your-workos-client-id
NEXT_PUBLIC_AUTHKIT_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_AUTHKIT_SCOPES=openid profile email
NEXT_PUBLIC_AUTHKIT_AUDIENCE=
