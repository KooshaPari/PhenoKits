# Normalize line endings to LF in repository, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly text files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
packages.lock.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.dll binary
*.exe binary
*.zip binary
*.nupkg binary
