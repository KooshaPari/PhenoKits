{
  "stryker-config": {
    "project": "src/SDK/DINOForge.SDK.csproj",
    "test-project": "src/Tests/DINOForge.Tests.csproj",
    "concurrency": 2,
    "dashboard": {
      "enabled": false
    },
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 60
    },
    "mutate": [
      "src/SDK/Models/**/*.cs",
      "src/Domains/Warfare/**/*.cs",
      "src/Domains/Economy/**/*.cs"
    ],
    "ignore-mutations": [
      "stringMutation",
      "linqMutation"
    ],
    "excludes": [
      "**/*.g.cs",
      "**/*.Generated.cs",
      "**/obj/**",
      "**/bin/**",
      "**/node_modules/**",
      "**/Test*/**"
    ],
    "additional-timeout-ms": 120000
  }
}
