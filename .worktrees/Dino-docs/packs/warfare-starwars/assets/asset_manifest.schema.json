{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DINOForge Asset Manifest Schema",
  "description": "Schema for asset intake manifests in the DINOForge Star Wars mod pack",
  "type": "object",
  "required": [
    "asset_id",
    "category",
    "source_url",
    "original_format"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "description": "Unique identifier for the asset (e.g., sw_clone_trooper_sketchfab_001)",
      "pattern": "^[a-z0-9_]+$"
    },
    "canonical_name": {
      "type": "string",
      "description": "Human-readable canonical name for the asset"
    },
    "franchise_tag": {
      "type": "string",
      "description": "Franchise identifier (e.g., 'star_wars')"
    },
    "faction": {
      "type": "string",
      "description": "Faction this asset belongs to (e.g., 'republic', 'cis')"
    },
    "category": {
      "type": "string",
      "enum": [
        "unit_model",
        "vehicle_model",
        "building_model",
        "weapon_model",
        "projectile_model",
        "vfx_asset",
        "sfx_asset",
        "ui_element",
        "texture_set",
        "rig",
        "animation",
        "other"
      ],
      "description": "Asset category"
    },
    "source_platform": {
      "type": "string",
      "enum": [
        "sketchfab",
        "blendswap",
        "moddb",
        "other"
      ],
      "description": "Platform where the asset was sourced from"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the source asset page"
    },
    "author_name": {
      "type": "string",
      "description": "Name of the original creator/author"
    },
    "license_label": {
      "type": "string",
      "description": "License label (e.g., 'CC BY 4.0', 'CC0', 'All Rights Reserved')"
    },
    "license_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to license documentation"
    },
    "acquisition_mode": {
      "type": "string",
      "enum": [
        "api",
        "download",
        "scrape",
        "browser_automation"
      ],
      "description": "How the asset was acquired"
    },
    "acquired_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when asset was acquired"
    },
    "original_format": {
      "type": "string",
      "enum": [
        "glb",
        "gltf",
        "obj",
        "fbx",
        "blend",
        "other"
      ],
      "description": "Original file format of the source asset"
    },
    "download_url": {
      "type": "string",
      "format": "uri",
      "description": "Direct download URL for the asset file (filled after acquisition)"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "SHA256 hash of the downloaded asset file for integrity verification"
    },
    "polycount_estimate": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated polygon count"
    },
    "texture_sets": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of material/texture sets included"
    },
    "rigged": {
      "type": "boolean",
      "description": "Whether the model includes a skeleton rig"
    },
    "animated": {
      "type": "boolean",
      "description": "Whether the asset includes animations"
    },
    "technical_status": {
      "type": "string",
      "enum": [
        "discovered",
        "metadata_fetched",
        "downloadable",
        "downloaded",
        "normalized",
        "validated",
        "ready_for_prototype",
        "rejected_technical"
      ],
      "description": "Technical processing status of the asset"
    },
    "ip_status": {
      "type": "string",
      "enum": [
        "generic_safe",
        "fan_star_wars_private_only",
        "official_game_mod_tool_reference_only",
        "unknown_provenance",
        "high_risk_do_not_ship"
      ],
      "description": "Intellectual property risk classification"
    },
    "provenance_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score (0-1) in the provenance assessment"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of notes about the asset (processing notes, warnings, etc.)"
    }
  },
  "additionalProperties": false
}
