{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dinoforge.dev/schemas/asset-library.schema.json",
  "title": "DINOForge Asset Library Catalog",
  "description": "Schema for the asset library catalog JSON export format.",
  "type": "object",
  "required": [
    "version",
    "exported_at",
    "assets"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for forward compatibility.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "exported_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the catalog was exported."
    },
    "source": {
      "type": "string",
      "description": "Optional source of the catalog export (e.g., 'local', 'catalog_store')."
    },
    "total_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of assets in the catalog."
    },
    "assets": {
      "type": "array",
      "description": "List of asset catalog entries.",
      "items": {
        "$ref": "#/definitions/AssetCatalogEntry"
      }
    },
    "statistics": {
      "type": "object",
      "description": "Optional catalog statistics.",
      "properties": {
        "by_faction": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "by_type": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "by_status": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "by_pack": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "definitions": {
    "AssetCatalogEntry": {
      "type": "object",
      "required": [
        "asset_id",
        "created_at"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable asset identifier."
        },
        "name": {
          "type": "string",
          "description": "Human-readable name or title."
        },
        "faction": {
          "type": "string",
          "enum": ["republic", "cis", "empire", "rebel", "neutral", "jedi", "sith", "scum", "unknown"],
          "description": "Faction classification."
        },
        "type": {
          "type": "string",
          "enum": ["unit", "vehicle", "building", "prop", "vfx", "audio", "ui", "misc"],
          "description": "Asset type category."
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "Source URL where the asset was discovered."
        },
        "status": {
          "type": "string",
          "description": "Technical or IP status of the asset."
        },
        "provenance": {
          "type": "string",
          "description": "Provenance information or source adapter name."
        },
        "pack_id": {
          "type": "string",
          "description": "Associated pack identifier."
        },
        "metadata_json": {
          "type": "string",
          "description": "Additional metadata as JSON string."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the asset was added to the catalog."
        }
      },
      "additionalProperties": false
    }
  }
}
