{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dinoforge.github.io/schemas/asset_manifest.schema.json",
  "title": "Asset Manifest Schema",
  "description": "Schema for managing individual asset intake, provenance, and lifecycle tracking in DINOForge",
  "type": "object",
  "required": [
    "asset_id",
    "category",
    "source_url"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "description": "Unique identifier for the asset (e.g., 'sw_clone_trooper_sketchfab_001')",
      "pattern": "^[a-z0-9_]+$",
      "minLength": 3,
      "maxLength": 100
    },
    "canonical_name": {
      "type": "string",
      "description": "Human-readable canonical name (e.g., 'Clone Trooper Phase II Armor')"
    },
    "franchise_tag": {
      "type": "string",
      "description": "IP/franchise tag for tracking (e.g., 'star_wars', 'generic', 'original')"
    },
    "faction": {
      "type": "string",
      "description": "In-game faction this asset belongs to (e.g., 'republic_clone_army', 'confederacy_of_independent_systems')"
    },
    "category": {
      "type": "string",
      "description": "Asset category for organization",
      "enum": [
        "character_model",
        "armor_variant",
        "weapon_mesh",
        "vehicle_model",
        "building_structure",
        "effect_vfx",
        "environment_prop",
        "ui_asset",
        "animation_rig",
        "texture_set",
        "material",
        "other"
      ]
    },
    "source_platform": {
      "type": "string",
      "description": "Platform where asset was sourced from",
      "enum": [
        "sketchfab",
        "blendswap",
        "moddb",
        "internal",
        "unknown"
      ]
    },
    "source_url": {
      "type": "string",
      "description": "URL to original asset on source platform (required)",
      "format": "uri"
    },
    "author_name": {
      "type": "string",
      "description": "Creator/artist name from source platform"
    },
    "license_label": {
      "type": "string",
      "description": "License label from source (e.g., 'CC BY 4.0', 'CC BY-NC', 'GPL-3.0')"
    },
    "license_url": {
      "type": "string",
      "description": "URL to license text",
      "format": "uri"
    },
    "acquisition_mode": {
      "type": "string",
      "description": "How the asset was acquired",
      "enum": [
        "api",
        "download",
        "scrape",
        "browser_automation",
        "manual_upload",
        "unknown"
      ]
    },
    "acquired_at_utc": {
      "type": "string",
      "description": "ISO 8601 timestamp when asset was acquired",
      "format": "date-time"
    },
    "original_format": {
      "type": "string",
      "description": "Original file format of the asset",
      "enum": [
        "glb",
        "gltf",
        "obj",
        "fbx",
        "blend",
        "usdz",
        "other"
      ]
    },
    "download_url": {
      "type": "string",
      "description": "Direct download URL (filled after successful download)",
      "format": "uri"
    },
    "sha256": {
      "type": "string",
      "description": "SHA256 hash of downloaded file for integrity verification",
      "pattern": "^[a-f0-9]{64}$"
    },
    "polycount_estimate": {
      "type": "number",
      "description": "Estimated polygon count",
      "minimum": 0
    },
    "texture_sets": {
      "type": "integer",
      "description": "Number of texture sets included",
      "minimum": 0
    },
    "rigged": {
      "type": "boolean",
      "description": "Whether the model is rigged with a skeleton"
    },
    "animated": {
      "type": "boolean",
      "description": "Whether the model includes animations"
    },
    "technical_status": {
      "type": "string",
      "description": "Current technical processing status",
      "enum": [
        "discovered",
        "metadata_fetched",
        "downloadable",
        "downloaded",
        "normalized",
        "validated",
        "ready_for_prototype",
        "rejected_technical"
      ]
    },
    "ip_status": {
      "type": "string",
      "description": "IP/legal status classification for release decisions",
      "enum": [
        "generic_safe",
        "fan_star_wars_private_only",
        "official_game_mod_tool_reference_only",
        "unknown_provenance",
        "high_risk_do_not_ship"
      ]
    },
    "provenance_confidence": {
      "type": "number",
      "description": "Confidence score (0-1) that IP status is correctly assessed",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "array",
      "description": "Array of notes about the asset (licensing concerns, modifications, etc.)",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "description": "Free-form tags for organization (e.g., 'hero_unit', 'clone_wars_era')",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional platform-specific metadata",
      "properties": {
        "sketchfab_model_id": {
          "type": "string"
        },
        "sketchfab_view_count": {
          "type": "integer"
        },
        "sketchfab_like_count": {
          "type": "integer"
        },
        "source_published_date": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "additionalProperties": false
}
