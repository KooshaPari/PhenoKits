{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dinoforge.dev/schemas/pack-manifest.schema.json",
  "title": "DINOForge Pack Manifest",
  "description": "Schema for DINOForge pack manifest files (pack.yaml).",
  "type": "object",
  "required": ["id", "name", "version", "author", "type"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "description": "Unique pack identifier (lowercase, hyphens, underscores)."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable pack name."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semantic version string."
    },
    "framework_version": {
      "type": "string",
      "description": "Required DINOForge framework version range."
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Pack author name."
    },
    "type": {
      "type": "string",
      "enum": ["content", "balance", "ruleset", "total_conversion", "utility"],
      "description": "Pack type category."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the pack."
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "List of pack IDs this pack depends on."
    },
    "conflicts_with": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "List of pack IDs this pack conflicts with."
    },
    "load_order": {
      "type": "integer",
      "default": 100,
      "description": "Load priority within the same dependency tier."
    },
    "game_version": {
      "type": "string",
      "description": "Compatible game version."
    },
    "loads": {
      "type": "object",
      "description": "Content type declarations to load.",
      "properties": {
        "factions": { "type": "array", "items": { "type": "string" } },
        "units": { "type": "array", "items": { "type": "string" } },
        "buildings": { "type": "array", "items": { "type": "string" } },
        "weapons": { "type": "array", "items": { "type": "string" } },
        "doctrines": { "type": "array", "items": { "type": "string" } },
        "audio": { "type": "array", "items": { "type": "string" } },
        "visuals": { "type": "array", "items": { "type": "string" } },
        "localization": { "type": "array", "items": { "type": "string" } },
        "wave_templates": { "type": "array", "items": { "type": "string" } },
        "tech_nodes": { "type": "array", "items": { "type": "string" } },
        "scenarios": { "type": "array", "items": { "type": "string" } },
        "faction_patches": { "type": "array", "items": { "type": "string" }, "description": "Faction patch definition IDs to apply to existing factions." }
      },
      "additionalProperties": false
    },
    "overrides": {
      "type": "object",
      "description": "Override declarations.",
      "properties": {
        "units": { "type": "array", "items": { "type": "string" } },
        "buildings": { "type": "array", "items": { "type": "string" } },
        "stats": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
