{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dinoforge.dev/schemas/unit.schema.json",
  "title": "DINOForge Unit Definition",
  "description": "Schema for DINOForge unit definition files (units/*.yaml).",
  "type": "object",
  "required": ["id", "display_name", "unit_class", "faction_id"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique unit identifier."
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable unit name."
    },
    "description": {
      "type": "string"
    },
    "unit_class": {
      "type": "string",
      "enum": [
        "MilitiaLight", "CoreLineInfantry", "EliteLineInfantry",
        "HeavyInfantry", "Skirmisher", "AntiArmor", "ShockMelee",
        "SwarmFodder", "FastVehicle", "MainBattleVehicle", "HeavySiege",
        "Artillery", "WalkerHeavy", "StaticMG", "StaticAT",
        "StaticArtillery", "SupportEngineer", "Recon", "HeroCommander",
        "AirstrikeProxy", "ShieldedElite"
      ],
      "description": "Unit class archetype."
    },
    "faction_id": {
      "type": "string",
      "minLength": 1,
      "description": "Faction this unit belongs to."
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Tech tier: 1=early, 2=mid, 3=late."
    },
    "stats": {
      "type": "object",
      "description": "Unit statistics.",
      "properties": {
        "hp": { "type": "number", "minimum": 0 },
        "damage": { "type": "number", "minimum": 0 },
        "armor": { "type": "number", "minimum": 0 },
        "range": { "type": "number", "minimum": 0 },
        "speed": { "type": "number", "minimum": 0 },
        "accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
        "fire_rate": { "type": "number", "minimum": 0 },
        "morale": { "type": "number", "minimum": 0 },
        "cost": { "$ref": "#/definitions/resource_cost" }
      },
      "additionalProperties": false
    },
    "weapon": {
      "type": "string",
      "description": "Weapon ID reference."
    },
    "defense_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Unarmored", "InfantryArmor", "HeavyArmor", "Fortified", "Shielded", "Mechanical", "Biological", "Heroic"]
      }
    },
    "behavior_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["HoldLine", "AdvanceFire", "Charge", "Kite", "Swarm", "SiegePriority", "AntiStructure", "AntiMass", "AntiArmor", "MoralePressure", "Aerial", "AntiAir"]
      }
    },
    "aerial": {
      "type": "object",
      "description": "Aerial movement and combat properties. Only applicable to units with the 'Aerial' behavior tag.",
      "properties": {
        "cruise_altitude": {
          "type": "number",
          "minimum": 0,
          "description": "Operational altitude in world units during normal flight."
        },
        "ascend_speed": {
          "type": "number",
          "minimum": 0,
          "description": "Rate of altitude gain in world units per second."
        },
        "descend_speed": {
          "type": "number",
          "minimum": 0,
          "description": "Rate of altitude loss in world units per second."
        },
        "anti_air": {
          "type": "boolean",
          "description": "Whether this aerial unit can engage other aerial targets."
        }
      },
      "additionalProperties": false
    },
    "visuals": {
      "type": "object",
      "properties": {
        "icon": { "type": "string" },
        "portrait": { "type": "string" },
        "model_override": { "type": "string" },
        "projectile_vfx": { "type": "string" },
        "muzzle_vfx": { "type": "string" }
      },
      "additionalProperties": false
    },
    "audio": {
      "type": "object",
      "properties": {
        "attack_sound": { "type": "string" },
        "death_sound": { "type": "string" },
        "select_sound": { "type": "string" },
        "move_sound": { "type": "string" }
      },
      "additionalProperties": false
    },
    "vanilla_mapping": {
      "type": "string",
      "description": "Vanilla DINO unit ID this replaces."
    },
    "tech_requirement": {
      "type": "string",
      "description": "Tech node ID required to unlock."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "resource_cost": {
      "type": "object",
      "properties": {
        "food": { "type": "integer", "minimum": 0 },
        "wood": { "type": "integer", "minimum": 0 },
        "stone": { "type": "integer", "minimum": 0 },
        "iron": { "type": "integer", "minimum": 0 },
        "gold": { "type": "integer", "minimum": 0 },
        "population": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
