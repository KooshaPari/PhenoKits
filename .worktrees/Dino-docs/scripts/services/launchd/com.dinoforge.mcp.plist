<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dinoforge.mcp</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>bash</string>
        <string>__REPO_ROOT__/scripts/start-mcp.sh</string>
        <string>--action</string>
        <string>start</string>
        <string>--foreground</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>DINOFORGE_PYTHON</key>
        <string>/usr/bin/python3</string>
        <key>DINO_GAME_DIR</key>
        <string>/path/to/Diplomacy is Not an Option</string>
        <key>BARE_CUA_NATIVE</key>
        <string>/path/to/bare-cua-native</string>
    </dict>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>__REPO_ROOT__/src/Tools/DinoforgeMcp</string>
    <key>StandardOutPath</key>
    <string>/tmp/dinoforge-mcp.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/dinoforge-mcp.err.log</string>
</dict>
</plist>