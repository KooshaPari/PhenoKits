{
  "$schema": "http://json.schemastore.org/template",
  "author": "DINOForge",
  "classifications": ["DINOForge", "Game Mod", "Pack"],
  "identity": "DINOForge.PackTemplate",
  "name": "DINOForge Mod Pack",
  "shortName": "dinoforge-pack",
  "description": "Scaffolds a DINOForge mod pack with manifest, content folders, and CI",
  "tags": {
    "language": "YAML",
    "type": "project"
  },
  "symbols": {
    "PackId": {
      "type": "parameter",
      "description": "Unique pack identifier (kebab-case, e.g. my-cool-mod)",
      "datatype": "string",
      "defaultValue": "my-pack",
      "replaces": "PACK_ID"
    },
    "PackName": {
      "type": "parameter",
      "description": "Human-readable pack name",
      "datatype": "string",
      "defaultValue": "My Pack",
      "replaces": "PACK_NAME"
    },
    "PackType": {
      "type": "parameter",
      "description": "Pack type: content, balance, ruleset, total_conversion, utility",
      "datatype": "choice",
      "choices": [
        {"choice": "content"},
        {"choice": "balance"},
        {"choice": "ruleset"},
        {"choice": "total_conversion"},
        {"choice": "utility"}
      ],
      "defaultValue": "content",
      "replaces": "PACK_TYPE"
    },
    "AuthorName": {
      "type": "parameter",
      "description": "Your name or handle",
      "datatype": "string",
      "defaultValue": "Anonymous",
      "replaces": "PACK_AUTHOR"
    },
    "GitHubUser": {
      "type": "parameter",
      "description": "Your GitHub username (for CI badge URLs)",
      "datatype": "string",
      "defaultValue": "yourusername",
      "replaces": "GITHUB_USER"
    }
  },
  "sources": [
    {
      "source": "./",
      "exclude": [".template.config/**"]
    }
  ]
}
