{
  "Sketchfab": {
    "ApiBaseUrl": "https://api.sketchfab.com/v3",
    "RateLimitDelayMs": 2000,
    "DefaultSearchLimit": 5,
    "MaxRetries": 3,
    "HttpTimeoutSeconds": 30
  },
  "AssetPipeline": {
    "DownloadDir": "packs/warfare-starwars/assets/raw",
    "CacheDir": ".cache/sketchfab",
    "TempDir": "/tmp/asset-downloads",
    "IntegrityCheckEnabled": true,
    "GenerateHashes": true,
    "AutoManifest": true
  },
  "Logging": {
    "LogLevel": "Information"
  }
}
