<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DINOForge.DesktopCompanion.Themes.Converters">

    <!-- Converters -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converters:ErrorCountToColorConverter x:Key="ErrorCountToColorConverter" />

    <!-- DINOForge dark colour tokens -->
    <Color x:Key="DFBackground">#FF1A1A1A</Color>
    <Color x:Key="DFSurface">#FF252525</Color>
    <Color x:Key="DFAccent">#FF4CAF50</Color>
    <Color x:Key="DFAccentHover">#FF66BB6A</Color>
    <Color x:Key="DFWarning">#FFFFA726</Color>
    <Color x:Key="DFError">#FFF44336</Color>
    <Color x:Key="DFSuccess">#FF4CAF50</Color>
    <Color x:Key="DFTextPrimary">#FFE0E0E0</Color>
    <Color x:Key="DFTextSecondary">#FF9E9E9E</Color>
    <Color x:Key="DFBorder">#FF333333</Color>

    <SolidColorBrush x:Key="DFBackgroundBrush" Color="{StaticResource DFBackground}" />
    <SolidColorBrush x:Key="DFSurfaceBrush" Color="{StaticResource DFSurface}" />
    <SolidColorBrush x:Key="DFAccentBrush" Color="{StaticResource DFAccent}" />
    <SolidColorBrush x:Key="DFWarningBrush" Color="{StaticResource DFWarning}" />
    <SolidColorBrush x:Key="DFErrorBrush" Color="{StaticResource DFError}" />
    <SolidColorBrush x:Key="DFSuccessBrush" Color="{StaticResource DFSuccess}" />
    <SolidColorBrush x:Key="DFTextPrimaryBrush" Color="{StaticResource DFTextPrimary}" />
    <SolidColorBrush x:Key="DFTextSecondaryBrush" Color="{StaticResource DFTextSecondary}" />
    <SolidColorBrush x:Key="DFBorderBrush" Color="{StaticResource DFBorder}" />

    <!-- Accent button style -->
    <Style x:Key="DFAccentButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DFAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- Card panel style -->
    <Style x:Key="DFCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DFSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DFBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Section header text -->
    <Style x:Key="DFSectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DFAccentBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- Body text -->
    <Style x:Key="DFBodyText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource DFTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <!-- Secondary text -->
    <Style x:Key="DFSecondaryText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource DFTextSecondaryBrush}" />
    </Style>

    <!-- Mono text for debug output -->
    <Style x:Key="DFMonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource DFTextPrimaryBrush}" />
    </Style>

</ResourceDictionary>
