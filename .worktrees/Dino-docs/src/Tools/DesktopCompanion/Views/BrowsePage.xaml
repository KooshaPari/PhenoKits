<Page
    x:Class="DINOForge.DesktopCompanion.Views.BrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="using:DINOForge.DesktopCompanion.Data"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Browse Packs"
            Style="{StaticResource TitleTextBlockStyle}"
            Foreground="{StaticResource DFAccentBrush}" />

        <!-- Catalog source input -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                x:Name="CatalogSourceBox"
                AutomationProperties.AutomationId="CatalogSourceBox"
                PlaceholderText="Enter catalog URL or folder path (e.g., https://example.com/catalog.json)"
                Text="{x:Bind ViewModel.CatalogSource, Mode=TwoWay}"
                Style="{StaticResource DFTextBoxStyle}" />

            <Button
                Grid.Column="1"
                x:Name="BrowseLoadButton"
                AutomationProperties.AutomationId="BrowseLoadButton"
                Content="Load"
                Style="{StaticResource DFAccentButton}"
                Command="{x:Bind ViewModel.LoadCatalogCommand}" />

            <Button
                Grid.Column="2"
                x:Name="BrowseRefreshButton"
                AutomationProperties.AutomationId="BrowseRefreshButton"
                Content="Refresh"
                Style="{StaticResource DFSecondaryButton}"
                Command="{x:Bind ViewModel.RefreshCommand}" />
        </Grid>

        <!-- Filters -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                x:Name="SearchBox"
                AutomationProperties.AutomationId="SearchBox"
                PlaceholderText="Search by name, author, or description…"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

            <ComboBox
                Grid.Column="1"
                x:Name="TypeFilterBox"
                AutomationProperties.AutomationId="TypeFilterBox"
                SelectedValue="{x:Bind ViewModel.FilterType, Mode=TwoWay}"
                Width="150">
                <ComboBoxItem Content="All" IsSelected="True" />
                <ComboBoxItem Content="content" />
                <ComboBoxItem Content="balance" />
                <ComboBoxItem Content="ruleset" />
                <ComboBoxItem Content="total_conversion" />
                <ComboBoxItem Content="utility" />
            </ComboBox>
        </Grid>

        <!-- Status + counts -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{StaticResource DFSecondaryText}"
                VerticalAlignment="Center" />

            <TextBlock
                Grid.Column="1"
                Style="{StaticResource DFSecondaryText}"
                VerticalAlignment="Center">
                <Run Text="{x:Bind ViewModel.Entries.Count, Mode=OneWay}" />
                <Run Text=" pack(s)" />
            </TextBlock>
        </Grid>

        <!-- Loading indicator -->
        <ProgressBar
            Grid.Row="4"
            IsIndeterminate="True"
            VerticalAlignment="Top"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            Margin="0,8,0,0" />

        <!-- Catalog entries list -->
        <ListView
            Grid.Row="4"
            x:Name="BrowseListView"
            Margin="0,16,0,0"
            ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}"
            SelectionMode="Single">

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="data:CatalogEntry">
                    <Border Style="{StaticResource DFCard}" Margin="0,4">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Pack info -->
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{StaticResource DFBodyText}"
                                    FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource DFSecondaryText}">
                                    <Run Text="{x:Bind Id}" />
                                    <Run Text=" • " />
                                    <Run Text="{x:Bind Version}" />
                                    <Run Text=" • " />
                                    <Run Text="{x:Bind Author}" />
                                </TextBlock>
                                <TextBlock
                                    Text="{x:Bind Type}"
                                    Style="{StaticResource DFSecondaryText}"
                                    Foreground="{StaticResource DFAccentBrush}" />
                                <TextBlock
                                    Text="{x:Bind Description}"
                                    Style="{StaticResource DFSecondaryText}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="400" />
                            </StackPanel>

                            <!-- Status badges -->
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <!-- Installed badge -->
                                <Border
                                    Background="{StaticResource DFSuccessBrush}"
                                    CornerRadius="12"
                                    Padding="8,2"
                                    Visibility="{x:Bind IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Installed" Foreground="White" FontSize="11" />
                                </Border>

                                <!-- Update badge -->
                                <Border
                                    Background="{StaticResource DFWarningBrush}"
                                    CornerRadius="12"
                                    Padding="8,2"
                                    Visibility="{x:Bind HasUpdate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Update" Foreground="White" FontSize="11" />
                                </Border>
                            </StackPanel>

                            <!-- Install button -->
                            <Button
                                Grid.Column="2"
                                x:Name="InstallButton"
                                Content="Install"
                                Style="{StaticResource DFAccentButton}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
