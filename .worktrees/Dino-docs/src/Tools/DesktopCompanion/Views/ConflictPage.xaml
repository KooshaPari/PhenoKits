<Page
    x:Class="DINOForge.DesktopCompanion.Views.ConflictPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="using:DINOForge.DesktopCompanion.Data"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Conflicts"
            Style="{StaticResource TitleTextBlockStyle}"
            Foreground="{StaticResource DFAccentBrush}" />

        <!-- Status + Analyze button -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{StaticResource DFSecondaryText}"
                VerticalAlignment="Center" />

            <Button
                Grid.Column="1"
                x:Name="AnalyzeButton"
                AutomationProperties.AutomationId="AnalyzeButton"
                Content="Analyze"
                Style="{StaticResource DFAccentButton}"
                Command="{x:Bind ViewModel.AnalyzeConflictsCommand}" />

            <Button
                Grid.Column="2"
                x:Name="RefreshButton"
                AutomationProperties.AutomationId="RefreshButton"
                Content="Refresh"
                Style="{StaticResource DFSecondaryButton}"
                Command="{x:Bind ViewModel.RefreshCommand}" />
        </Grid>

        <!-- Summary badges -->
        <Grid Grid.Row="2" ColumnSpacing="16" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Conflict count badge -->
            <Border
                Grid.Column="0"
                Background="{StaticResource DFErrorBrush}"
                CornerRadius="16"
                Padding="12,6"
                Visibility="{x:Bind ViewModel.ConflictCount, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.ConflictCount, Mode=OneWay}" Foreground="White" FontWeight="Bold" />
                    <TextBlock Text="Conflicts" Foreground="White" />
                </StackPanel>
            </Border>

            <!-- Dependency issues badge -->
            <Border
                Grid.Column="1"
                Background="{StaticResource DFWarningBrush}"
                CornerRadius="16"
                Padding="12,6"
                Visibility="{x:Bind ViewModel.DependencyIssueCount, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.DependencyIssueCount, Mode=OneWay}" Foreground="White" FontWeight="Bold" />
                    <TextBlock Text="Dependency Issues" Foreground="White" />
                </StackPanel>
            </Border>

            <!-- No issues indicator -->
            <Border
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource DFSuccessBrush}"
                CornerRadius="16"
                Padding="12,6"
                Visibility="{x:Bind ViewModel.HasIssues, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <TextBlock Text="No issues detected" Foreground="White" FontWeight="Bold" />
            </Border>
        </Grid>

        <!-- Loading indicator -->
        <ProgressBar
            Grid.Row="3"
            IsIndeterminate="True"
            VerticalAlignment="Top"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            Margin="0,8,0,0" />

        <!-- Main content: conflicts, dependencies, and load order -->
        <Grid Grid.Row="3" Margin="0,16,0,0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Conflicts list -->
            <Border Grid.Column="0" Style="{StaticResource DFCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Conflicts"
                        Style="{StaticResource DFSectionHeader}" />

                    <ListView
                        Grid.Row="1"
                        x:Name="ConflictsListView"
                        ItemsSource="{x:Bind ViewModel.Conflicts, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="data:ConflictItem">
                                <Border Margin="0,4">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="{x:Bind Message}"
                                            Style="{StaticResource DFBodyText}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Dependency issues list -->
            <Border Grid.Column="1" Style="{StaticResource DFCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Missing Dependencies"
                        Style="{StaticResource DFSectionHeader}" />

                    <ListView
                        Grid.Row="1"
                        x:Name="DependencyIssuesListView"
                        ItemsSource="{x:Bind ViewModel.DependencyIssues, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="data:DependencyIssue">
                                <Border Margin="0,4">
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource DFBodyText}">
                                            <Run Text="{x:Bind PackName}" FontWeight="SemiBold" />
                                            <Run Text=" (" />
                                            <Run Text="{x:Bind PackId}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource DFSecondaryText}">
                                            <Run Text="Missing: " />
                                            <Run Text="{x:Bind MissingDependencyId}" Foreground="{StaticResource DFErrorBrush}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Load order + dependency tree -->
            <Border Grid.Column="2" Style="{StaticResource DFCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Load Order"
                        Style="{StaticResource DFSectionHeader}" />

                    <ComboBox
                        Grid.Row="1"
                        x:Name="PackSelector"
                        AutomationProperties.AutomationId="PackSelector"
                        ItemsSource="{x:Bind ViewModel.LoadOrder, Mode=OneWay}"
                        SelectedValue="{x:Bind ViewModel.SelectedPackId, Mode=TwoWay}"
                        PlaceholderText="Select pack for tree view"
                        Margin="0,0,0,8" />

                    <ListView
                        Grid.Row="2"
                        x:Name="DependencyTreeView"
                        ItemsSource="{x:Bind ViewModel.DependencyTree, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="data:DependencyTreeNode">
                                <Border Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Indentation spacer -->
                                        <Rectangle
                                            Grid.Column="0"
                                            Width="{x:Bind Depth, Converter={StaticResource DepthToWidthConverter}}"
                                            Fill="Transparent" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource DFBodyText}">
                                            <Run Text="{x:Bind PackName}" FontWeight="SemiBold" />
                                            <Run Text=" v" />
                                            <Run Text="{x:Bind Version}" />
                                            <Run Text=" " Foreground="Transparent">|</Run>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
