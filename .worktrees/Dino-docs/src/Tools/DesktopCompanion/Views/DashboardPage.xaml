<Page
    x:Class="DINOForge.DesktopCompanion.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="800">

            <!-- Header -->
            <TextBlock
                Text="Dashboard"
                Style="{StaticResource TitleTextBlockStyle}"
                Foreground="{StaticResource DFAccentBrush}" />

            <!-- Status banner (error) -->
            <InfoBar
                x:Name="ErrorBanner"
                IsOpen="{x:Bind ViewModel.HasErrors, Mode=OneWay}"
                Severity="Error"
                Title="Pack Load Errors"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

            <!-- Status banner (success) -->
            <InfoBar
                x:Name="SuccessBanner"
                IsOpen="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Severity="Informational"
                Title="Loading"
                Message="Scanning packs directoryâ€¦" />

            <!-- Summary cards -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Packs loaded -->
                <Border Grid.Column="0" Style="{StaticResource DFCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Packs Loaded" Style="{StaticResource DFSecondaryText}" />
                        <TextBlock
                            x:Name="DashLoadedCount"
                            AutomationProperties.AutomationId="DashLoadedCount"
                            Text="{x:Bind ViewModel.LoadedCount, Mode=OneWay}"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="{StaticResource DFAccentBrush}" />
                    </StackPanel>
                </Border>

                <!-- Errors -->
                <Border Grid.Column="1" Style="{StaticResource DFCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Load Errors" Style="{StaticResource DFSecondaryText}" />
                        <TextBlock
                            x:Name="DashErrorCount"
                            AutomationProperties.AutomationId="DashErrorCount"
                            Text="{x:Bind ViewModel.ErrorCount, Mode=OneWay}"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="{x:Bind ViewModel.ErrorCount, Mode=OneWay, Converter={StaticResource ErrorCountToColorConverter}}" />
                    </StackPanel>
                </Border>

                <!-- Packs directory -->
                <Border Grid.Column="2" Style="{StaticResource DFCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Packs Directory" Style="{StaticResource DFSecondaryText}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.PacksDirectory, Mode=OneWay}"
                            Style="{StaticResource DFBodyText}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{x:Bind ViewModel.PacksDirectory, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status message -->
            <Border Style="{StaticResource DFCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status" Style="{StaticResource DFSectionHeader}" />
                    <TextBlock
                        x:Name="DashStatusText"
                        AutomationProperties.AutomationId="DashStatusText"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        Style="{StaticResource DFBodyText}" />
                </StackPanel>
            </Border>

            <!-- Refresh button -->
            <Button
                x:Name="DashRefreshButton"
                AutomationProperties.AutomationId="DashRefreshButton"
                Content="Refresh Packs"
                Style="{StaticResource DFAccentButton}"
                Command="{x:Bind ViewModel.RefreshCommand}"
                IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                HorizontalAlignment="Left" />

        </StackPanel>
    </ScrollViewer>
</Page>
