# Example environment configuration for HexaType.
# Copy this file to `.env` and uncomment the variables you need.

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# DEBUG=false
# NODE_ENV=production
# LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Domain Configuration
# ------------------------------------------------------------------------------
# DOMAIN_NAME=hexatype-app
# ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# External Services (if using adapters)
# ------------------------------------------------------------------------------
# API_BASE_URL=https://api.example.com
# DATABASE_URL=postgresql://user:pass@localhost:5432/hexatype
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret
