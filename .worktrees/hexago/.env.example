# Example environment configuration for HexaGo.
# Copy this file to `.env` and uncomment the variables you need.

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# DEBUG=false
# LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Domain Configuration
# ------------------------------------------------------------------------------
# DOMAIN_NAME=go-hex-app
# ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# External Services (if using adapters)
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/hexago
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret
