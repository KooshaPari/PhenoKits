# phenotype-cipher - Cryptographic library
# Required environment variables

# Key Configuration
CIPHER_MASTER_KEY=your-256-bit-key-here
CIPHER_KEY_ROTATION_DAYS=90

# Logging
RUST_LOG=info,cipher=debug

# Crypto Configuration
CIPHER_BACKEND=ring  # ring, openssl, or aws-kms
CIPHER_AES_KEY_SIZE=256

# Security
CIPHER_HARDENED=true
CIPHER_ZEROIZE=true
