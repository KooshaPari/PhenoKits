# phenotype-dep-guard - Rust dependency guard CLI
# Required environment variables

# Dep-guard Configuration
DEP_GUARD_CONFIG_DIR=~/.config/phenotype-dep-guard
DEP_GUARD_DATA_DIR=~/.local/share/phenotype-dep-guard

# Logging
RUST_LOG=info,dep_guard=debug

# Validation Rules
DEP_GUARD_STRICT_MODE=false
DEP_GUARD_ALLOWED_LICENSES=MIT,Apache-2.0,BSD-3-Clause
DEP_GUARD_BLOCKED_CRATES=dangerous_crate

# API (optional)
DEP_GUARD_API_URL=https://api.phenotype.dev
DEP_GUARD_API_TOKEN=your-token-here
