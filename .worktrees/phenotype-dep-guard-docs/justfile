# phenotype-dep-guard - Rust dependency guard CLI
# Native task runner (just)

# Default recipe
default: help

# Help
help:
  @echo "phenotype-dep-guard - Rust dependency guard CLI"
  @echo ""
  @just --list

# Quality checks
check: fmt clippy test
  @echo "All checks passed!"

# Format code
fmt:
  cargo fmt --all

# Lint
clippy:
  cargo clippy --workspace -- -D warnings

# Run tests
test:
  cargo test --workspace

# Build
build:
  cargo build --release

# Run CLI
dev:
  cargo run --bin dep-guard --watch

# Clean
clean:
  cargo clean --workspace

# Integration tests
integration:
  cargo test --test integration

# Benchmarks
bench:
  cargo bench --workspace
