# phenotype-forge - Forge CLI
# Required environment variables

# Forge Configuration
FORGE_CONFIG_DIR=~/.config/phenotype-forge
FORGE_DATA_DIR=~/.local/share/phenotype-forge

# Logging
RUST_LOG=info,phenotype_forge=debug

# API Configuration
FORGE_API_URL=https://api.phenotype.dev
FORGE_API_TOKEN=your-token-here

# Editor
FORGE_EDITOR=vim
FORGE_PAGER=less
