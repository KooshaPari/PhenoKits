# phenotype-forge - Forge CLI
# Native task runner (just)

# Default recipe
default: help

# Help
help:
  @echo "phenotype-forge - Forge CLI"
  @echo ""
  @just --list

# Quality checks
check: fmt clippy test
  @echo "All checks passed!"

# Format code
fmt:
  cargo fmt --all

# Lint
clippy:
  cargo clippy --workspace -- -D warnings

# Run tests
test:
  cargo test --workspace

# Build
build:
  cargo build --release

# Run CLI
dev:
  cargo run --bin phenotype-forge --watch

# Clean
clean:
  cargo clean

# Benchmarks
bench:
  cargo bench --workspace
