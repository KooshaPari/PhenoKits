{
  "name": "phenotype-nexus-docs",
  "version": "0.1.0",
  "scripts": {
    "docs:install": "pnpm install",
    "docs:build": "vitepress build",
    "docs:serve": "vitepress serve dist",
    "docs:dev": "vitepress dev",
    "docs:test:unit": "node --test tests/unit/*.test.mjs",
    "docs:test:component": "node --test tests/component/*.test.mjs",
    "docs:test:e2e": "playwright test --config tests/playwright.config.ts",
    "docs:test": "npm run docs:test:unit && npm run docs:test:component && npm run docs:test:e2e",
    "docs:check": "npm run docs:build && npm run docs:test",
    "docs:evidence": "npm run docs:build"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vueuse/core": "^11.2.0",
    "mermaid": "^10.11.4",
    "shiki": "^1.26.3",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.4.20",
    "vue": "^3.5.11"
  }
}
