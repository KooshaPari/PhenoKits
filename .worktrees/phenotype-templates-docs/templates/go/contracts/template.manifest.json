{
  "layer_type": "language",
  "layer_name": "template-lang-go",
  "version": "0.2.0",
  "depends_on": [
    {"layer": "template-commons", "version": ">=0.1.0"}
  ],
  "owned_paths": [
    "templates/go/**",
    "contracts/**",
    "docs/**",
    "scripts/**"
