    "templates/go/domain/entities/entity.go",
    "templates/go/domain/entities/example.go",
    "templates/go/domain/ports/inbound/usecase.go",
    "templates/go/domain/ports/outbound/repository.go",
    "templates/go/domain/valueobjects/vo.go",
    "templates/go/application/commands/handler.go",
    "templates/go/infrastructure/adapters/persistence/memory.go",
    "templates/go/infrastructure/http/handlers.go",
    "templates/go/infrastructure/http/server.go",
    "templates/go/Makefile"
  ]
}
