# phenotype-xdd-lib - Rust cross-document exchange library
# Required environment variables

# Library Configuration
XDD_CONFIG_PATH=./xdd.toml

# Logging
RUST_LOG=info,xdd=debug

# Cache Configuration
XDD_CACHE_DIR=./.xdd-cache
XDD_CACHE_TTL_SECS=3600

# Network (optional)
XDD_PROXY_URL=
XDD_TIMEOUT_SECS=30
