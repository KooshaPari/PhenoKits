#!/bin/bash
# Sync script for portage (no upstream)

set -e

BRANCH="${1:-main}"

echo "=== Syncing portage ==="
echo "Target branch: $BRANCH"

# Check for uncommitted changes
if ! git diff-index --quiet HEAD --; then
    echo "ERROR: Working tree has uncommitted changes. Commit or stash them first."
    exit 1
fi

# Ensure target branch exists and is tracked
if ! git show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
    echo "ERROR: Branch '$BRANCH' does not exist in origin"
    exit 1
fi

# Switch to target branch
git switch "$BRANCH" 2>/dev/null || git checkout "$BRANCH"

# Fetch latest from origin
git fetch origin

# Check if we can fast-forward
LOCAL="$(git rev-parse HEAD)"
REMOTE="$(git rev-parse "origin/$BRANCH")"

if [[ "$LOCAL" == "$REMOTE" ]]; then
    echo "Already up-to-date with origin/$BRANCH"
elif git merge-base --is-ancestor "$LOCAL" "$REMOTE"; then
    echo "origin/$BRANCH is ahead. Merging..."
    git merge --no-ff "origin/$BRANCH" -m "Merge origin/$BRANCH into $BRANCH"
elif git merge-base --is-ancestor "$REMOTE" "$LOCAL"; then
    echo "Local $BRANCH is ahead of origin/$BRANCH. Nothing to merge."
else
    echo "Local and origin/$BRANCH have diverged. Merging..."
    git merge --no-ff "origin/$BRANCH" -m "Merge origin/$BRANCH into $BRANCH"
fi

echo "=== Sync complete ==="
git log --oneline -3
