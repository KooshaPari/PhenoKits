# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.rs text diff=rust
*.py text diff=python
*.js text diff=javascript
*.ts text diff=javascript
*.go text diff=golang
*.sh text eol=lf
*.yml text
*.yaml text
*.toml text
*.json text
*.md text

# Documentation
*.txt text
*.adoc text
*.rst text

# Config files
.env* text
.gitattributes text
.gitignore text
.editorconfig text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tar.gz binary
*.rar binary
*.7z binary

# Rust
*.lock text
Cargo.lock linguist-generated=true

# Python
*.pyc binary
*.pyo binary
*.pyd binary
__pycache__ binary
*.egg binary
*.egg-info binary
*.whl binary

# Node
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true
node_modules binary

# Go
go.sum text
go.mod text
vendor binary

# Misc
*.db binary
*.sqlite binary
*.sqlite3 binary
