/**
 * Unit tests for domain entities and value objects
 */

import { describe, it, expect } from 'vitest';

// Entity interface
interface Entity<Id> {
  id: Id;
  equals(other: Entity<Id>): boolean;
}

// Value object interface
interface ValueObject<T> {
  equals(other: ValueObject<T>): boolean;
  value(): T;
}

// Example entity implementation
class UserEntity implements Entity<string> {
  constructor(
    public readonly id: string,
    public readonly name: string,
    public readonly email: string
  ) {}

  equals(other: Entity<string>): boolean {
    return this.id === other.id;
  }
}

// Example value object implementation
class EmailValueObject implements ValueObject<string> {
  constructor(private readonly _value: string) {
    if (!this._value.includes('@')) {
      throw new Error('Invalid email address');
    }
  }

  value(): string {
    return this._value;
  }

  equals(other: ValueObject<string>): boolean {
    return this._value === other.value();
  }
}

describe('Entity', () => {
  it('should create entity with id', () => {
    const user = new UserEntity('user-123', 'John Doe', 'john@example.com');

    expect(user.id).toBe('user-123');
    expect(user.name).toBe('John Doe');
    expect(user.email).toBe('john@example.com');
  });

  it('should be equal to entity with same id', () => {
    const user1 = new UserEntity('user-123', 'John', 'john@example.com');
    const user2 = new UserEntity('user-123', 'Jane', 'jane@example.com');

    expect(user1.equals(user2)).toBe(true);
  });

  it('should not be equal to entity with different id', () => {
    const user1 = new UserEntity('user-123', 'John', 'john@example.com');
    const user2 = new UserEntity('user-456', 'John', 'john@example.com');

    expect(user1.equals(user2)).toBe(false);
  });
});

describe('ValueObject', () => {
  it('should create valid email value object', () => {
    const email = new EmailValueObject('test@example.com');

    expect(email.value()).toBe('test@example.com');
  });

  it('should throw for invalid email', () => {
    expect(() => new EmailValueObject('invalid-email')).toThrow(
      'Invalid email address'
    );
  });

  it('should be equal to email with same value', () => {
    const email1 = new EmailValueObject('test@example.com');
    const email2 = new EmailValueObject('test@example.com');

    expect(email1.equals(email2)).toBe(true);
  });

  it('should not be equal to email with different value', () => {
    const email1 = new EmailValueObject('test@example.com');
    const email2 = new EmailValueObject('other@example.com');

    expect(email1.equals(email2)).toBe(false);
  });
});
