---
/**
 * Global search bar for Phenotype Dev Hub
 * Integrates search across all federated product docsites
 */

const products = [
  { slug: 'focalpoint', name: 'FocalPoint' },
  { slug: 'agileplus', name: 'AgilePlus' },
  { slug: 'tracera', name: 'Tracera' },
  { slug: 'paginary', name: 'Paginary' },
  { slug: 'sidekick', name: 'Sidekick' }
];
---

<div class="flex items-center gap-2">
  <form id="global-search-form" class="w-full max-w-xs">
    <div class="relative">
      <input
        type="search"
        id="global-search-input"
        placeholder="Search docs..."
        autocomplete="off"
        class="w-full rounded-lg border border-slate-700 bg-slate-800 px-4 py-2 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
      />
      <select
        id="search-product"
        class="absolute right-1 top-1/2 -translate-y-1/2 rounded bg-slate-700 px-2 py-1 text-xs text-slate-200 focus:outline-none"
      >
        <option value="">All Products</option>
        {products.map(product => (
          <option value={product.slug}>{product.name}</option>
        ))}
      </select>
    </div>
  </form>
</div>

<script define:vars={{ products }}>
  const searchForm = document.getElementById('global-search-form');
  const searchInput = document.getElementById('global-search-input');
  const searchProduct = document.getElementById('search-product');

  if (searchForm && searchInput && searchProduct) {
    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();

      const query = searchInput.value.trim();
      const product = searchProduct.value;

      if (!query) return;

      // Map products to search endpoints
      const searchEndpoints = {
        focalpoint: 'https://focalpoint.phenotype.dev/search',
        agileplus: 'https://agileplus.phenotype.dev/search',
        tracera: 'https://tracera.phenotype.dev/search',
        paginary: 'https://paginary.phenotype.dev/search',
        sidekick: 'https://sidekick.phenotype.dev/search'
      };

      if (product && searchEndpoints[product]) {
        // Search a specific product
        const searchUrl = new URL(searchEndpoints[product]);
        searchUrl.searchParams.set('q', query);
        window.location.href = searchUrl.toString();
      } else {
        // Default: open docs index with query parameter
        const docsUrl = new URL('/docs', window.location.origin);
        docsUrl.searchParams.set('q', query);
        window.location.href = docsUrl.toString();
      }
    });

    // Quick keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      // Cmd/Ctrl + K to focus search
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        searchInput.focus();
      }

      // Escape to blur search
      if (e.key === 'Escape' && document.activeElement === searchInput) {
        searchInput.blur();
      }
    });
  }
</script>

<style>
  /* Hide select dropdown arrow in Firefox */
  select {
    appearance: none;
    background-image: none;
    padding-right: 1.5rem;
  }

  /* Hide select dropdown arrow in Chrome/Edge */
  select::-ms-expand {
    display: none;
  }
</style>
