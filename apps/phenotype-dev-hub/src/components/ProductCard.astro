---
export interface Props {
  slug: string;
  name: string;
  description: string;
  accent: string;
  icon: string;
  status?: 'stable' | 'beta' | 'alpha';
}

const { slug, name, description, accent, icon, status } = Astro.props;

const statusColors: Record<string, string> = {
  stable: 'bg-green-900/30 text-green-400',
  beta: 'bg-yellow-900/30 text-yellow-400',
  alpha: 'bg-orange-900/30 text-orange-400'
};
---

<a
  href={`/products/${slug}`}
  class="group relative overflow-hidden rounded-lg border border-slate-700 bg-slate-800 p-6 transition-all hover:border-slate-600 hover:bg-slate-700 hover:shadow-xl hover:shadow-slate-900/50"
>
  <div class="relative z-10">
    <div class="flex items-start justify-between">
      <div class={`inline-flex rounded-lg bg-${accent}-900/30 p-3 text-2xl`}>
        {icon}
      </div>
      {status && (
        <span class={`rounded-full px-2.5 py-1 text-xs font-semibold ${statusColors[status] || statusColors.stable}`}>
          {status}
        </span>
      )}
    </div>
    <h3 class="mt-4 text-xl font-bold text-white">{name}</h3>
    <p class="mt-2 text-sm text-slate-300">{description}</p>
    <div class="mt-4 inline-flex items-center text-sm font-semibold text-slate-300 group-hover:text-slate-100">
      View product
      <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
  </div>
  <div class={`absolute -right-8 -top-8 h-32 w-32 rounded-full bg-${accent}-500/20 opacity-0 transition-opacity group-hover:opacity-100`}></div>
</a>
