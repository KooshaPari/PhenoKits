---
import ThemeProvider from '../components/ThemeProvider.astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Phenotype',
  description = 'Developer hub for Phenotype organization',
  canonical
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical URL -->
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Global Styles -->
    <style is:global>
      * {
        box-sizing: border-box;
      }
      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }
      img, video {
        max-width: 100%;
        height: auto;
      }
      input, button, textarea, select {
        font: inherit;
      }
      p, h1, h2, h3, h4, h5, h6 {
        overflow-wrap: break-word;
      }

      /* Light mode overrides */
      .light {
        --bg-primary: #f8f7f6;
        --bg-secondary: #ffffff;
        --bg-tertiary: #f3f2f1;
        --text-primary: #1a1a1a;
        --text-secondary: #555555;
        --border: #e0e0e0;
      }

      .light {
        background-color: var(--bg-primary);
        color: var(--text-primary);
      }

      .light body {
        @apply bg-white text-slate-950;
      }

      .light .bg-slate-950 {
        @apply bg-white;
      }

      .light .bg-slate-900 {
        @apply bg-slate-100;
      }

      .light .bg-slate-800 {
        @apply bg-slate-200;
      }

      .light .bg-slate-700 {
        @apply bg-slate-300;
      }

      .light .text-white {
        @apply text-slate-950;
      }

      .light .text-slate-100 {
        @apply text-slate-900;
      }

      .light .text-slate-300 {
        @apply text-slate-700;
      }

      .light .text-slate-400 {
        @apply text-slate-600;
      }

      .light .border-slate-700 {
        @apply border-slate-300;
      }

      .light .border-slate-800 {
        @apply border-slate-200;
      }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 dark:bg-slate-950 dark:text-slate-100">
    <ThemeProvider>
      <slot />
    </ThemeProvider>
  </body>
</html>
