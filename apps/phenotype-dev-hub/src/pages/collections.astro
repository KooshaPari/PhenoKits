---
import Layout from '../layouts/Layout.astro';
import CollectionCard from '../components/CollectionCard.astro';
import Footer from '../components/Footer.astro';

const collections = [
  {
    name: 'Sidekick',
    slug: 'sidekick',
    tagline: 'AI-powered agent framework for autonomous task execution',
    accent: 'orange',
    icon: '🤖',
    theme: 'agent utilities',
    description: 'Polyglot Rust + Python workspace of agent utility crates',
    crates: 4,
    github: 'https://github.com/kooshapari/Sidekick'
  },
  {
    name: 'Eidolon',
    slug: 'eidolon',
    tagline: 'Unified trait-based device automation',
    accent: 'purple',
    icon: '🎮',
    theme: 'device automation',
    description: 'Unified trait-based device automation for desktop, mobile, sandbox',
    crates: 3,
    github: 'https://github.com/kooshapari/Eidolon'
  },
  {
    name: 'Stashly',
    slug: 'stashly',
    tagline: 'Cache, stash, retrieve—instantly',
    accent: 'teal',
    icon: '💾',
    theme: 'storage & persistence',
    description: 'Independent storage crates: caching, event sourcing, state machines',
    crates: 3,
    github: 'https://github.com/kooshapari/Stashly'
  },
  {
    name: 'Observably',
    slug: 'observably',
    tagline: 'Observability and distributed tracing',
    accent: 'sky',
    icon: '📊',
    theme: 'observability',
    description: 'Independent observability crates: tracing, logging, metrics, resilience',
    crates: 4,
    github: 'https://github.com/kooshapari/Observably'
  },
  {
    name: 'Paginary',
    slug: 'paginary',
    tagline: 'Progressive pagination and infinite scroll',
    accent: 'emerald',
    icon: '📖',
    theme: 'documentation',
    description: 'Federated documentation hub with VitePress apps and shared theme',
    crates: 3,
    github: 'https://github.com/kooshapari/Paginary'
  },
  {
    name: 'phenotype-shared',
    slug: 'phenotype-shared',
    tagline: 'Rust infrastructure toolkit',
    accent: 'indigo',
    icon: '🔧',
    theme: 'shared infrastructure',
    description: 'Domain-driven design, hexagonal architecture, clean separation',
    crates: 6,
    github: 'https://github.com/kooshapari/phenotype-shared'
  }
];
---

<Layout
  title="Collections | Phenotype Hub"
  description="Explore Phenotype's curated collections of open-source crates and frameworks"
>
  <section class="border-b border-slate-800 bg-gradient-to-b from-slate-900 to-slate-950 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <h1 class="text-5xl font-bold text-white sm:text-6xl">Collections</h1>
        <p class="mt-4 text-xl text-slate-300">
          Explore our curated collections of open-source projects and frameworks
        </p>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {collections.map(collection => (
          <div class="group relative overflow-hidden rounded-lg border border-slate-700 bg-slate-800 p-8 transition-all hover:border-slate-600 hover:bg-slate-700 hover:shadow-xl hover:shadow-slate-900/50">
            <div class="relative z-10">
              <div class="mb-4 inline-flex rounded-lg bg-slate-700 p-3 text-3xl">
                {collection.icon}
              </div>

              <h3 class="text-2xl font-bold text-white">{collection.name}</h3>

              <p class="mt-2 text-sm font-medium text-slate-400">{collection.theme}</p>

              <p class="mt-3 text-base text-slate-300">{collection.tagline}</p>

              <p class="mt-4 text-sm text-slate-400">
                {collection.description}
              </p>

              <div class="mt-6 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-semibold text-slate-400">CRATES</span>
                  <span class="rounded-full bg-slate-700 px-2 py-1 text-sm font-bold text-slate-200">
                    {collection.crates}
                  </span>
                </div>
              </div>

              <div class="mt-6 flex flex-col gap-2">
                <a
                  href={`/collections/${collection.slug}`}
                  class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors"
                >
                  View Collection
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
                <a
                  href={collection.github}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center justify-center rounded-lg border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-300 hover:border-slate-500 hover:text-white hover:bg-slate-700 transition-colors"
                >
                  GitHub
                  <svg class="ml-2 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                  </svg>
                </a>
              </div>
            </div>

            <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-slate-700/20 opacity-0 transition-opacity group-hover:opacity-100"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-slate-800 bg-slate-900 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="rounded-lg border border-slate-700 bg-slate-800 p-8">
        <h3 class="text-2xl font-bold text-white">Learn More</h3>
        <p class="mt-4 text-slate-300">
          Each collection features independent crates with detailed documentation, examples, and integration guides.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/"
            class="inline-flex items-center rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-600 transition-colors"
          >
            Back to Home
          </a>
          <a
            href="https://github.com/kooshapari"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-600 transition-colors"
          >
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Import Footer -->
  <script is:inline>
    // Placeholder for footer import if needed
  </script>
</Layout>
