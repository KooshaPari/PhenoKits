---
import Layout from '../../../layouts/Layout.astro';

interface DocSite {
  name: string;
  docsUrl: string;
  searchUrl: string;
  status: 'stable' | 'beta' | 'alpha';
}

const docSites: Record<string, DocSite> = {
  focalpoint: {
    name: 'FocalPoint',
    docsUrl: 'https://focalpoint.phenotype.dev/docs',
    searchUrl: 'https://focalpoint.phenotype.dev/search',
    status: 'stable'
  },
  agileplus: {
    name: 'AgilePlus',
    docsUrl: 'https://agileplus.phenotype.dev/docs',
    searchUrl: 'https://agileplus.phenotype.dev/search',
    status: 'stable'
  },
  tracera: {
    name: 'Tracera',
    docsUrl: 'https://tracera.phenotype.dev/docs',
    searchUrl: 'https://tracera.phenotype.dev/search',
    status: 'beta'
  },
  paginary: {
    name: 'Paginary',
    docsUrl: 'https://paginary.phenotype.dev/docs',
    searchUrl: 'https://paginary.phenotype.dev/search',
    status: 'stable'
  },
  sidekick: {
    name: 'Sidekick',
    docsUrl: 'https://sidekick.phenotype.dev/docs',
    searchUrl: 'https://sidekick.phenotype.dev/search',
    status: 'beta'
  }
};

export function getStaticPaths() {
  return [
    { params: { product: 'focalpoint', slug: undefined } },
    { params: { product: 'agileplus', slug: undefined } },
    { params: { product: 'tracera', slug: undefined } },
    { params: { product: 'paginary', slug: undefined } },
    { params: { product: 'sidekick', slug: undefined } }
  ];
}

const { product, slug } = Astro.params;
const docSite = docSites[product];

if (!docSite) {
  return Astro.redirect('/404');
}

// Build the target URL
const path = slug ? `/${slug}` : '';
const targetUrl = `${docSite.docsUrl}${path}`;
---

<Layout title={`${docSite.name} Docs | Phenotype`} description={`${docSite.name} documentation and guides`}>
  <div class="min-h-screen bg-slate-950">
    <!-- Navigation Bar -->
    <nav class="border-b border-slate-800 bg-slate-900">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center gap-4">
            <a href="/" class="text-slate-400 hover:text-white transition-colors">Phenotype Hub</a>
            <span class="text-slate-600">/</span>
            <span class="text-white font-semibold">{docSite.name}</span>
            <span class="ml-2 inline-flex items-center rounded-full bg-slate-700 px-3 py-1 text-xs font-medium text-slate-200">
              {docSite.status}
            </span>
          </div>
          <div class="flex items-center gap-4">
            <a
              href={docSite.searchUrl}
              class="text-sm text-slate-400 hover:text-white transition-colors"
              target="_blank"
              rel="noopener"
            >
              Search
            </a>
            <a
              href="/"
              class="text-sm text-slate-400 hover:text-white transition-colors"
            >
              Back to Hub
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Docs Content Area -->
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="rounded-lg border border-slate-700 bg-slate-800 p-8 text-center">
        <h1 class="text-3xl font-bold text-white mb-4">{docSite.name} Documentation</h1>
        <p class="text-slate-300 mb-8">
          Redirecting you to the {docSite.name} documentation site. If you are not automatically redirected, click the button below.
        </p>
        <a
          href={targetUrl}
          target="_blank"
          rel="noopener"
          class="inline-block rounded-lg bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-700 transition-colors"
        >
          Visit {docSite.name} Docs
        </a>

        <!-- Redirect Script -->
        <script define:vars={{ targetUrl }}>
          // Auto-redirect after 1 second
          setTimeout(() => {
            window.location.href = targetUrl;
          }, 1000);
        </script>
      </div>

      <!-- Alternative: Docs Index with Links to All Products -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-white mb-6">Documentation Index</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/docs/focalpoint" class={`rounded-lg border p-6 transition-all ${product === 'focalpoint' ? 'border-blue-500 bg-blue-500/10' : 'border-slate-700 bg-slate-800 hover:border-slate-600'}`}>
            <h3 class="text-lg font-semibold text-white">FocalPoint</h3>
            <p class="mt-2 text-sm text-slate-400">stable</p>
          </a>
          <a href="/docs/agileplus" class={`rounded-lg border p-6 transition-all ${product === 'agileplus' ? 'border-blue-500 bg-blue-500/10' : 'border-slate-700 bg-slate-800 hover:border-slate-600'}`}>
            <h3 class="text-lg font-semibold text-white">AgilePlus</h3>
            <p class="mt-2 text-sm text-slate-400">stable</p>
          </a>
          <a href="/docs/tracera" class={`rounded-lg border p-6 transition-all ${product === 'tracera' ? 'border-blue-500 bg-blue-500/10' : 'border-slate-700 bg-slate-800 hover:border-slate-600'}`}>
            <h3 class="text-lg font-semibold text-white">Tracera</h3>
            <p class="mt-2 text-sm text-slate-400">beta</p>
          </a>
          <a href="/docs/paginary" class={`rounded-lg border p-6 transition-all ${product === 'paginary' ? 'border-blue-500 bg-blue-500/10' : 'border-slate-700 bg-slate-800 hover:border-slate-600'}`}>
            <h3 class="text-lg font-semibold text-white">Paginary</h3>
            <p class="mt-2 text-sm text-slate-400">stable</p>
          </a>
          <a href="/docs/sidekick" class={`rounded-lg border p-6 transition-all ${product === 'sidekick' ? 'border-blue-500 bg-blue-500/10' : 'border-slate-700 bg-slate-800 hover:border-slate-600'}`}>
            <h3 class="text-lg font-semibold text-white">Sidekick</h3>
            <p class="mt-2 text-sm text-slate-400">beta</p>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
