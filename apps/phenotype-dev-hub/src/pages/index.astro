---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CollectionCard from '../components/CollectionCard.astro';
import ProductCard from '../components/ProductCard.astro';
import Footer from '../components/Footer.astro';

const collections = [
  {
    name: 'Sidekick',
    slug: 'sidekick',
    tagline: 'AI-powered agent framework for autonomous task execution',
    accent: 'sidekick',
    icon: '🤖'
  },
  {
    name: 'Eidolon',
    slug: 'eidolon',
    tagline: 'Semantic search and RAG infrastructure',
    accent: 'eidolon',
    icon: '🔍'
  },
  {
    name: 'Paginary',
    slug: 'paginary',
    tagline: 'Progressive pagination and infinite scroll toolkit',
    accent: 'paginary',
    icon: '📖'
  },
  {
    name: 'Observably',
    slug: 'observably',
    tagline: 'Observability and distributed tracing platform',
    accent: 'observably',
    icon: '📊'
  },
  {
    name: 'Stashly',
    slug: 'stashly',
    tagline: 'Decentralized storage and content addressing',
    accent: 'stashly',
    icon: '💾'
  }
];

const products = [
  {
    name: 'FocalPoint',
    slug: 'focalpoint',
    description: 'Production-grade AI development platform with multi-model support, fine-tuning, and deployment infrastructure',
    accent: 'focalpoint',
    icon: '🎯',
    status: 'stable'
  },
  {
    name: 'AgilePlus',
    slug: 'agileplus',
    description: 'Work management and agile planning platform with integrated observability and team collaboration',
    accent: 'agileplus',
    icon: '⚡',
    status: 'stable'
  },
  {
    name: 'Tracera',
    slug: 'tracera',
    description: 'Distributed tracing and performance analysis system for complex microservice architectures',
    accent: 'tracera',
    icon: '🔗',
    status: 'beta'
  },
  {
    name: 'hwLedger',
    slug: 'hwledger',
    description: 'Blockchain-based ledger system with cryptographic verification and distributed consensus',
    accent: 'hwledger',
    icon: '📜',
    status: 'alpha'
  }
];
---

<Layout title="Phenotype Hub | Developer Platform" description="Discover Phenotype's ecosystem of developer tools, frameworks, and products">
  <Hero />

  <!-- Collections Section -->
  <section id="collections" class="bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <h2 class="text-4xl font-bold text-white">Collections</h2>
        <p class="mt-4 text-lg text-slate-400">Discover our curated collections of open-source projects and frameworks</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
        {collections.map(collection => (
          <CollectionCard
            slug={collection.slug}
            name={collection.name}
            tagline={collection.tagline}
            accent={collection.accent}
            icon={collection.icon}
          />
        ))}
      </div>

      <div class="mt-12 text-center">
        <a
          href="/collections"
          class="inline-flex items-center rounded-lg bg-slate-700 px-6 py-3 font-semibold text-white hover:bg-slate-600 transition-colors"
        >
          View All Collections
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="border-t border-slate-800 bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <h2 class="text-4xl font-bold text-white">Products</h2>
        <p class="mt-4 text-lg text-slate-400">Production-grade platforms built on our collections</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {products.map(product => (
          <ProductCard
            slug={product.slug}
            name={product.name}
            description={product.description}
            accent={product.accent}
            icon={product.icon}
            status={product.status}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Docs Federation Section -->
  <section class="border-t border-slate-800 bg-slate-900 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="rounded-lg border border-slate-700 bg-slate-800 p-8">
        <h3 class="text-2xl font-bold text-white">Documentation & Community</h3>
        <p class="mt-4 text-slate-300">
          Explore comprehensive documentation, guides, and examples for all our projects
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a
            href="https://docs.phenotype.dev"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-3 rounded-lg bg-slate-700 p-4 hover:bg-slate-600 transition-colors"
          >
            <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C6.5 6.253 2 10.998 2 17s4.5 10.747 10 10.747c5.5 0 10-4.998 10-10.747S17.5 6.253 12 6.253z"></path>
            </svg>
            <span class="text-sm font-semibold text-white">Documentation</span>
          </a>
          <a
            href="https://github.com/kooshapari"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-3 rounded-lg bg-slate-700 p-4 hover:bg-slate-600 transition-colors"
          >
            <svg class="h-6 w-6 text-slate-200" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            <span class="text-sm font-semibold text-white">GitHub</span>
          </a>
          <a
            href="https://github.com/kooshapari/phenotype-infrakit/discussions"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-3 rounded-lg bg-slate-700 p-4 hover:bg-slate-600 transition-colors"
          >
            <svg class="h-6 w-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a2 2 0 01-2-2v-6a2 2 0 012-2h8z"></path>
            </svg>
            <span class="text-sm font-semibold text-white">Discussions</span>
          </a>
          <a
            href="https://github.com/kooshapari/phenotype-infrakit/issues"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-3 rounded-lg bg-slate-700 p-4 hover:bg-slate-600 transition-colors"
          >
            <svg class="h-6 w-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-sm font-semibold text-white">Issues & Support</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
