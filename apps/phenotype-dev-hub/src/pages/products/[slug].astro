---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

// Import product data
import focalpointData from '../../content/products/focalpoint.json';
import agileplusData from '../../content/products/agileplus.json';
import traceraData from '../../content/products/tracera.json';
import hwledgerData from '../../content/products/hwledger.json';

const products = [focalpointData, agileplusData, traceraData, hwledgerData];

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

const statusColors: Record<string, { bg: string; text: string }> = {
  stable: { bg: 'bg-green-900/30', text: 'text-green-400' },
  beta: { bg: 'bg-yellow-900/30', text: 'text-yellow-400' },
  alpha: { bg: 'bg-orange-900/30', text: 'text-orange-400' }
};

const colors = statusColors[product.status] || statusColors.stable;
---

<Layout title={`${product.name} - Phenotype Hub`} description={product.details.overview}>
  <header class="border-b border-slate-800 bg-slate-900 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="flex items-start justify-between">
        <div class="flex items-center gap-4">
          <div class={`rounded-lg bg-${product.accent}-900/30 p-4 text-4xl`}>
            {product.icon}
          </div>
          <div>
            <h1 class="text-4xl font-bold text-white">{product.name}</h1>
            <p class="mt-2 text-lg text-slate-400">{product.tagline}</p>
          </div>
        </div>
        <span class={`rounded-full px-4 py-2 text-sm font-semibold ${colors.bg} ${colors.text}`}>
          {product.status}
        </span>
      </div>
    </div>
  </header>

  <main class="bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <!-- Overview -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-white">Overview</h2>
        <p class="mt-4 text-lg text-slate-300">{product.details.overview}</p>
      </section>

      <!-- Features -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-white">Features</h2>
        <ul class="mt-6 space-y-4">
          {product.details.features.map((feature: string) => (
            <li class="flex items-start gap-4">
              <svg class="h-6 w-6 flex-shrink-0 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-lg text-slate-300">{feature}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Links -->
      <section>
        <h2 class="text-2xl font-bold text-white">Resources</h2>
        <div class="mt-6 flex flex-wrap gap-4">
          {product.links.website && (
            <a
              href={product.links.website}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-700 transition-colors"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Visit Website
            </a>
          )}
          <a
            href={product.links.github}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg bg-slate-700 px-6 py-3 font-semibold text-white hover:bg-slate-600 transition-colors"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            GitHub
          </a>
          <a
            href={product.links.docs}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg bg-slate-700 px-6 py-3 font-semibold text-white hover:bg-slate-600 transition-colors"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C6.5 6.253 2 10.998 2 17s4.5 10.747 10 10.747c5.5 0 10-4.998 10-10.747S17.5 6.253 12 6.253z"></path>
            </svg>
            Documentation
          </a>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-lg bg-slate-800 px-6 py-3 font-semibold text-slate-300 hover:text-white hover:bg-slate-700 transition-colors"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back Home
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>
