{
  "buildCommand": "bun run build",
  "devCommand": "astro dev",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/sidekick",
      "destination": "/collections/sidekick",
      "permanent": false
    },
    {
      "source": "/eidolon",
      "destination": "/collections/eidolon",
      "permanent": false
    },
    {
      "source": "/paginary",
      "destination": "/collections/paginary",
      "permanent": false
    },
    {
      "source": "/observably",
      "destination": "/collections/observably",
      "permanent": false
    },
    {
      "source": "/stashly",
      "destination": "/collections/stashly",
      "permanent": false
    },
    {
      "source": "/focalpoint",
      "destination": "/products/focalpoint",
      "permanent": false
    },
    {
      "source": "/agileplus",
      "destination": "/products/agileplus",
      "permanent": false
    },
    {
      "source": "/tracera",
      "destination": "/products/tracera",
      "permanent": false
    },
    {
      "source": "/hwledger",
      "destination": "/products/hwledger",
      "permanent": false
    },
    {
      "source": "/docs/focalpoint/:path*",
      "destination": "https://focalpoint.phenotype.dev/docs/:path*",
      "permanent": false
    },
    {
      "source": "/docs/agileplus/:path*",
      "destination": "https://agileplus.phenotype.dev/docs/:path*",
      "permanent": false
    },
    {
      "source": "/docs/tracera/:path*",
      "destination": "https://tracera.phenotype.dev/docs/:path*",
      "permanent": false
    },
    {
      "source": "/docs/paginary/:path*",
      "destination": "https://paginary.phenotype.dev/docs/:path*",
      "permanent": false
    },
    {
      "source": "/docs/sidekick/:path*",
      "destination": "https://sidekick.phenotype.dev/docs/:path*",
      "permanent": false
    }
  ]
}
