---
interface Props {
  name: string;
  description: string | null;
  url: string;
  topics: string[];
  isPrivate: boolean;
  isArchived: boolean;
  stargazerCount: number;
  pushedAt: string;
}

const { name, description, url, topics, isPrivate, isArchived, stargazerCount, pushedAt } = Astro.props;

const getStatusBadge = (archived: boolean, isPrivate: boolean) => {
  if (archived) return { text: 'Archived', color: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-400' };
  if (isPrivate) return { text: 'Private', color: 'bg-amber-50 text-amber-700 dark:bg-amber-900 dark:text-amber-200' };
  return { text: 'Active', color: 'bg-green-50 text-green-700 dark:bg-green-900 dark:text-green-200' };
};

const status = getStatusBadge(isArchived, isPrivate);
const lastUpdate = new Date(pushedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<article class="rounded-lg border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md hover:border-brand-300 dark:hover:border-brand-600 transition-all">
  <div class="flex items-start justify-between gap-4 mb-4">
    <a href={url} target="_blank" rel="noopener noreferrer" class="flex-1">
      <h3 class="text-lg font-semibold text-brand-600 hover:text-brand-700 dark:hover:text-brand-400 break-words">
        {name}
      </h3>
    </a>
    <span class={`px-2 py-1 rounded text-xs font-medium whitespace-nowrap ${status.color}`}>
      {status.text}
    </span>
  </div>

  {description && (
    <p class="text-gray-700 dark:text-gray-300 text-sm mb-3 line-clamp-2">
      {description}
    </p>
  )}

  <div class="flex flex-wrap gap-2 mb-4">
    {topics.slice(0, 3).map(topic => (
      <span class="px-2 py-1 bg-blue-50 dark:bg-blue-900 text-blue-700 dark:text-blue-200 rounded text-xs font-medium">
        {topic}
      </span>
    ))}
    {topics.length > 3 && (
      <span class="px-2 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded text-xs font-medium">
        +{topics.length - 3} more
      </span>
    )}
  </div>

  <div class="flex items-center gap-4 text-xs text-gray-600 dark:text-gray-400">
    {stargazerCount > 0 && (
      <span>⭐ {stargazerCount}</span>
    )}
    <span>Updated {lastUpdate}</span>
  </div>
</article>
