---
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoCard from '../components/RepoCard.astro';
import fs from 'fs';
import path from 'path';

// Load repo data from JSON
const reposPath = path.resolve('data/repos.json');
let repos = [];

if (fs.existsSync(reposPath)) {
  const reposRaw = JSON.parse(fs.readFileSync(reposPath, 'utf-8'));
  // Filter out archived repos (can be toggled via query param)
  repos = Array.isArray(reposRaw) ? reposRaw : reposRaw.repositories || [];
  // Sort by pushed date descending
  repos.sort((a, b) => new Date(b.pushedAt).getTime() - new Date(a.pushedAt).getTime());
}

const totalRepos = repos.length;
const activeRepos = repos.filter(r => !r.isArchived).length;
const publicRepos = repos.filter(r => !r.isPrivate).length;
const allTopics = Array.from(new Set(repos.flatMap(r => r.topics || []))).sort();
---

<BaseLayout title="Portfolio" description="All active KooshaPari GitHub repositories">
  <section class="mb-12">
    <h1 class="text-4xl font-bold mb-4">Project Portfolio</h1>
    <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
      Active repositories from the Phenotype organization ecosystem.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <div class="rounded-lg bg-blue-50 dark:bg-blue-900 p-4">
        <div class="text-3xl font-bold text-blue-700 dark:text-blue-200">{totalRepos}</div>
        <div class="text-sm text-blue-600 dark:text-blue-300">Total Repositories</div>
      </div>
      <div class="rounded-lg bg-green-50 dark:bg-green-900 p-4">
        <div class="text-3xl font-bold text-green-700 dark:text-green-200">{activeRepos}</div>
        <div class="text-sm text-green-600 dark:text-green-300">Active Projects</div>
      </div>
      <div class="rounded-lg bg-purple-50 dark:bg-purple-900 p-4">
        <div class="text-3xl font-bold text-purple-700 dark:text-purple-200">{publicRepos}</div>
        <div class="text-sm text-purple-600 dark:text-purple-300">Public</div>
      </div>
    </div>
  </section>

  <section>
    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">Projects ({activeRepos})</h2>
      <p class="text-gray-600 dark:text-gray-400 text-sm">
        Showing active, non-archived repositories. Data synced from GitHub.
      </p>
    </div>

    {repos.length === 0 ? (
      <div class="rounded-lg border-2 border-dashed border-gray-300 dark:border-gray-600 p-12 text-center">
        <p class="text-gray-600 dark:text-gray-400">
          No repository data available. Run <code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded text-sm">npm run sync:repos</code> to fetch.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {repos.map(repo => (
          <RepoCard
            name={repo.name}
            description={repo.description}
            url={repo.url}
            topics={repo.topics || []}
            isPrivate={repo.isPrivate}
            isArchived={repo.isArchived}
            stargazerCount={repo.stargazerCount}
            pushedAt={repo.pushedAt}
          />
        ))}
      </div>
    )}
  </section>

  <section class="mt-12 pt-12 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-2xl font-bold mb-4">Topics</h2>
    <div class="flex flex-wrap gap-2">
      {allTopics.map(topic => (
        <a href={`#${topic}`} class="px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
          {topic}
        </a>
      ))}
    </div>
  </section>

  {/* Build info */}
  <section class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-700 text-xs text-gray-500 dark:text-gray-500">
    <p>Built {new Date().toISOString()} | Repos: {totalRepos} | Active: {activeRepos}</p>
  </section>
</BaseLayout>
